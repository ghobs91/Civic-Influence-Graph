{
  "name": "civic-influence-graph",
  "version": "0.1.0",
  "private": true,
  "description": "Open, self-hostable platform mapping money, lobbying, and legislative behavior in U.S. politics",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "services/*",
    "web",
    "extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}
