# =============================================================================
# Civic Influence Graph — Environment Configuration
# =============================================================================
# Copy to .env and fill in values:  cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=cig
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cig
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- OpenSearch ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# --- API ---
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated allowed CORS origins (no wildcard in production).
CORS_ORIGIN=http://localhost:3000

# Comma-separated API keys for /export endpoints.
EXPORT_API_KEYS=replace-with-a-strong-random-key

# Comma-separated bearer tokens for /saved-queries endpoints.
SAVED_QUERY_BEARER_TOKENS=replace-with-a-strong-random-token

# --- Web ---
WEB_PORT=3000
# Server-side URL the Next.js rewrite proxy uses to reach the API.
# In Docker: http://api:3001  — Outside Docker: http://localhost:3001
INTERNAL_API_URL=http://localhost:3001

# --- Data Ingestion ---
FEC_API_KEY=DEMO_KEY
CIG_JURISDICTIONS=federal,CA,TX,NY,FL,IL
CIG_ELECTION_CYCLES=2024,2026

# --- P2P ---
P2P_DATA_DIR=./data/corestore
